# Crawler v2 — Environment Variables
# Copy to .env and fill in values

# MySQL Database (same as jkse-crawler)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=jkse_db

# Concurrency
CRAWLER_V2_CONCURRENCY=10
BATCH_SIZE=500

# Proxy configuration
PROXY_FILE=crawler_v2/proxies.txt
PROXY_TEST_URL=https://httpbin.org/ip
PROXY_TIMEOUT=10
PROXY_ROTATION_MODE=round_robin
PROXY_MAX_DOMAIN_HITS=10
PROXY_FAIL_THRESHOLD=3

# Anti-block / Rate limiting
CRAWL_DELAY_MIN=2
CRAWL_DELAY_MAX=5
MAX_RETRIES=3

# Gap detection
GAP_FILL_PRIORITY_FIELDS=pe_ratio,roe,net_margin
GAP_STALE_DAYS=3
GAP_FILL_INTERVAL_HOURS=6

# Schema detection
SELECTOR_STORE_PATH=crawler_v2/selector_store.json

# Logging
LOG_LEVEL=INFO

# Evaluation
V2_TARGET_SCORE=90.0
